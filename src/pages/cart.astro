---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionContainer from '../components/SectionContainer.astro';
import { getProducts } from '../lib/catalog';
import { SITE } from '../config/site';

const products = await getProducts();
const catalog = products.map((product) => ({
  sku: product.sku,
  name: product.name,
  format: product.format,
  priceCents: product.priceCents,
  imageUrl: product.imageUrl,
}));
---

<BaseLayout
  title="Cart | Ana’s Estate"
  description="Review your Ana’s Estate olive oil order before checkout."
  canonical={`${SITE.url}/cart`}
>
  <main class="cart-page" data-cart-page data-catalog={JSON.stringify(catalog)}>
    <div data-cart-hero hidden>
      <PageHero
        label="Your Cart"
        title="Shopping Cart"
        titleId="cart-title"
        description="Review your items and quantities before continuing to checkout."
      />
    </div>

    <section class="cart-empty" data-cart-empty aria-label="Shopping cart">
      <div class="cart-empty__inner">
        <p class="section-label">Cart</p>
        <h2>Your cart is empty</h2>
        <div class="ornament" aria-hidden="true">◇</div>
        <p>Browse our olive oil formats and add items when you are ready.</p>
        <a class="btn" href="/products">Back to shop</a>
      </div>
    </section>

    <section class="cart-section" data-cart-content hidden aria-label="Shopping cart">
      <SectionContainer>
        <div class="cart-content">
          <div class="cart-lines" data-cart-lines></div>

          <aside class="cart-summary">
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <strong data-cart-subtotal>$0.00</strong>
            </div>
            <p class="cart-summary__note">Shipping is calculated at checkout. All prices are in Canadian dollars.</p>
            <a class="btn" href="/checkout">Checkout</a>
          </aside>
        </div>
      </SectionContainer>
    </section>
  </main>

  <script src="../scripts/cart-page.ts"></script>
</BaseLayout>
