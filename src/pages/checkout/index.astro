---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { SITE } from '../../config/site';
import { getProducts } from '../../lib/catalog';

export const prerender = false;

const products = await getProducts();
const catalog = products.map((product) => ({
  sku: product.sku,
  name: product.name,
  format: product.format,
  priceCents: product.priceCents,
  imageUrl: product.imageUrl,
}));
---

<BaseLayout
  title="Checkout | Ana’s Estate"
  description="Complete your Anas Estate order."
  canonical={`${SITE.url}/checkout`}
>
  <main class="checkout-page">
    <section class="checkout-empty policy-section" data-checkout-empty>
      <div class="checkout-empty__inner reveal">
        <p class="section-label">Checkout</p>
        <h1>Your cart is empty</h1>
        <div class="ornament" aria-hidden="true">◇</div>
        <p>Add olive oil from the shop before continuing to checkout.</p>
        <a class="btn" href="/products">Back to shop</a>
      </div>
    </section>

    <div data-checkout-shell hidden>
      <PageHero
        label="Secure Checkout"
        title="Complete Your Order"
        titleId="checkout-title"
        description="Enter your information below for final order details."
      />

      <section class="checkout-section checkout-section--subpage">
        <div class="checkout-layout">
          <div
            class="checkout-grid reveal"
            data-checkout
            data-catalog={JSON.stringify(catalog)}
          >
            <div class="checkout-panel">
              <h2>Shipping Details</h2>
              <form id="checkout-address-form" class="checkout-form" autocomplete="on" novalidate>
                <div class="checkout-field" data-field="name">
                  <label for="checkout-name">Full name</label>
                  <input
                    id="checkout-name"
                    name="name"
                    type="text"
                    autocomplete="shipping name"
                    autocapitalize="words"
                    required
                  />
                  <p class="checkout-field__error" role="alert" hidden></p>
                </div>

                <div class="checkout-form__row">
                  <div class="checkout-field" data-field="email">
                    <label for="checkout-email">Email</label>
                    <input
                      id="checkout-email"
                      name="email"
                      type="email"
                      autocomplete="shipping email"
                      required
                    />
                    <p class="checkout-field__error" role="alert" hidden></p>
                  </div>
                  <div class="checkout-field" data-field="phone">
                    <label for="checkout-phone">Phone</label>
                    <input
                      id="checkout-phone"
                      name="phone"
                      type="tel"
                      autocomplete="shipping tel"
                      inputmode="tel"
                      required
                    />
                    <p class="checkout-field__error" role="alert" hidden></p>
                  </div>
                </div>

                <div class="checkout-field" data-field="addressLine1">
                  <label for="checkout-address-line-1">Street address</label>
                  <input
                    id="checkout-address-line-1"
                    name="addressLine1"
                    type="text"
                    autocomplete="shipping address-line1"
                    required
                  />
                  <p class="checkout-field__error" role="alert" hidden></p>
                </div>

                <div class="checkout-field" data-field="addressLine2">
                  <label for="checkout-address-line-2">Apartment, suite, or unit (optional)</label>
                  <input
                    id="checkout-address-line-2"
                    name="addressLine2"
                    type="text"
                    autocomplete="shipping address-line2"
                  />
                  <p class="checkout-field__error" role="alert" hidden></p>
                </div>

                <div class="checkout-form__row">
                  <div class="checkout-field" data-field="city">
                    <label for="checkout-city">City</label>
                    <input
                      id="checkout-city"
                      name="city"
                      type="text"
                      autocomplete="shipping address-level2"
                      autocapitalize="words"
                      required
                    />
                    <p class="checkout-field__error" role="alert" hidden></p>
                  </div>
                  <div class="checkout-field" data-field="region">
                    <label for="checkout-region">Province</label>
                    <select
                      id="checkout-region"
                      name="region"
                      autocomplete="shipping address-level1"
                      required
                    >
                      <option value="AB">Alberta</option>
                      <option value="BC">British Columbia</option>
                      <option value="MB">Manitoba</option>
                      <option value="NB">New Brunswick</option>
                      <option value="NL">Newfoundland and Labrador</option>
                      <option value="NS">Nova Scotia</option>
                      <option value="NT">Northwest Territories</option>
                      <option value="NU">Nunavut</option>
                      <option value="ON" selected={true}>Ontario</option>
                      <option value="PE">Prince Edward Island</option>
                      <option value="QC">Quebec</option>
                      <option value="SK">Saskatchewan</option>
                      <option value="YT">Yukon</option>
                    </select>
                    <p class="checkout-field__error" role="alert" hidden></p>
                  </div>
                </div>

                <div class="checkout-form__row">
                  <div class="checkout-field" data-field="postalCode">
                    <label for="checkout-postal-code">Postal code</label>
                    <input
                      id="checkout-postal-code"
                      name="postalCode"
                      type="text"
                      autocomplete="shipping postal-code"
                      autocapitalize="characters"
                      required
                    />
                    <p class="checkout-field__error" role="alert" hidden></p>
                  </div>
                  <div class="checkout-field" data-field="country">
                    <label for="checkout-country">Country</label>
                    <select
                      id="checkout-country"
                      name="country"
                      autocomplete="shipping country-code"
                      required
                    >
                      <option value="CA" selected={true}>Canada</option>
                    </select>
                    <p class="checkout-field__error" role="alert" hidden></p>
                  </div>
                </div>

                <button class="btn" type="submit">Continue</button>
              </form>

              <p id="checkout-error" class="checkout-error" role="alert" hidden></p>
            </div>

            <aside class="checkout-summary">
              <h2>Order Summary</h2>
              <div class="checkout-summary__products" data-checkout-lines></div>
              <dl class="checkout-summary__lines">
                <div>
                  <dt>Products</dt>
                  <dd id="summary-products">$0.00</dd>
                </div>
                <div class="checkout-summary__shipping">
                  <div class="checkout-summary__shipping-line">
                    <dt>Shipping</dt>
                    <dd id="summary-shipping">Complete shipping details</dd>
                  </div>
                  <p id="shipping-status" class="checkout-status" hidden></p>
                  <div
                    id="shipping-options"
                    class="summary-shipping-options"
                    role="radiogroup"
                    aria-label="Shipping method"
                    hidden
                  ></div>
                </div>
                <div class="checkout-summary__total">
                  <dt>Total</dt>
                  <dd id="summary-total">$0.00</dd>
                </div>
              </dl>
              <button id="checkout-pay" class="btn" type="button" disabled>
                Checkout
              </button>
              <p class="checkout-summary__note">
                You will complete checkout securely on Stripe. All prices are in Canadian
                dollars.
              </p>
            </aside>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script src="../../scripts/checkout.ts"></script>
</BaseLayout>
