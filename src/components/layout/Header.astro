---
import { Image } from 'astro:assets';
import { images } from '../../assets/images';
import SectionContainer from '../SectionContainer.astro';

interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;

const section = (id: string) => (isHome ? `#${id}` : `/#${id}`);
const homeHref = isHome ? '#top' : '/';
---

<header class="site-header">
  <SectionContainer class="site-header__inner">
    <nav class="nav nav-left" aria-label="Primary navigation">
      <a href={section('story')}>Our Story</a>
      <a href={section('origin')}>Our Olive Oil</a>
      <a href={section('harvest')}>Harvest</a>
    </nav>

    <a class="logo" href={homeHref} aria-label="Ana’s Estate home">
      <Image src={images.logo} alt="Ana’s Estate" loading="eager" />
    </a>

    <nav class="nav nav-right" aria-label="Secondary navigation">
      <a href={section('tasting')}>Taste Profile</a>
      <a href={section('products')}>Shop</a>
      <a href={section('contact')}>Contact</a>
    </nav>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </SectionContainer>

  <nav class="mobile-nav" id="mobile-menu" aria-label="Mobile navigation">
    <a href={section('story')}>Our Story</a>
    <a href={section('origin')}>Our Olive Oil</a>
    <a href={section('harvest')}>Harvest</a>
    <a href={section('quality')}>Quality</a>
    <a href={section('tasting')}>Taste Profile</a>
    <a href={section('products')}>Shop</a>
    <a href={section('contact')}>Contact</a>
  </nav>
</header>

<script>
  const menuToggle = document.querySelector('.menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');

  function closeMobileMenu() {
    if (!menuToggle || !mobileNav) return;
    mobileNav.classList.remove('is-open');
    menuToggle.classList.remove('is-open');
    menuToggle.setAttribute('aria-expanded', 'false');
  }

  if (menuToggle && mobileNav) {
    menuToggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.toggle('is-open');
      menuToggle.classList.toggle('is-open', isOpen);
      menuToggle.setAttribute('aria-expanded', String(isOpen));
    });

    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobileMenu);
    });

    document.addEventListener('click', (event) => {
      const target = event.target as Node;
      if (!mobileNav.contains(target) && !menuToggle.contains(target)) {
        closeMobileMenu();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMobileMenu();
    });
  }
</script>
