---
import { Image } from 'astro:assets';
import { images } from '../../assets/images';
import { FORMSUBMIT_ACTION, SITE } from '../../config/site';
import SectionContainer from '../SectionContainer.astro';

interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;

const section = (id: string) => (isHome ? `#${id}` : `/#${id}`);
---

<footer class="site-footer">
  <div class="greek-line" aria-hidden="true"></div>

  <SectionContainer class="footer-main">
    <div class="brand-col">
      <Image src={images.logoWhite} alt="Ana’s Estate" loading="lazy" />
      <p>
        Premium Extra Virgin Olive Oil from our family groves in Kalamata, Greece.
      </p>
      <p>Tradition. Quality. Purity.</p>
    </div>

    <div>
      <h4>Explore</h4>
      <a href={section('story')}>Our Story</a>
      <a href={section('origin')}>Our Olive Oil</a>
      <a href={section('harvest')}>Harvest</a>
      <a href={section('quality')}>Quality</a>
      <a href="/shop">Shop</a>
      {isHome && <a href={section('tasting')}>Taste Profile</a>}
    </div>

    <div>
      <h4>Customer Care</h4>
      <a href="/contact">Contact</a>
      <a href="/policies/shipping">Shipping and Delivery</a>
      <a href="/contact">Wholesale Inquiries</a>
      <a href="/files/label.pdf" target="_blank" rel="noopener">Product Label</a>
    </div>

    <div>
      <h4>Stay Connected</h4>
      <p>
        {
          isHome
            ? 'Sign up for recipes, harvest updates and news from our family groves.'
            : 'Sign up for harvest updates and news from our family groves.'
        }
      </p>

      <form class="newsletter" action={FORMSUBMIT_ACTION} method="POST">
        <input type="hidden" name="_subject" value="Ana’s Estate newsletter signup form submission" />
        <input type="hidden" name="_captcha" value="false" />

        <label for="newsletter-email" hidden>Email address</label>

        <input
          id="newsletter-email"
          type="email"
          name="email"
          placeholder="Enter your email"
          required
        />

        <button type="submit" aria-label="Subscribe">›</button>
      </form>
    </div>
  </SectionContainer>

  <SectionContainer class="footer-bottom">
    <span>© {new Date().getFullYear()} {SITE.name}. All rights reserved.</span>
    <span>Product of Greece / Produit de Grèce</span>
    <span>Imported by {SITE.companyName}</span>
  </SectionContainer>
</footer>
