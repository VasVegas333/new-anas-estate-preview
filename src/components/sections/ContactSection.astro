---
import { FORMSUBMIT_ACTION, SITE } from '../../config/site';
import SectionContainer from '../SectionContainer.astro';
---

<section class="contact-section" id="contact" aria-labelledby="contact-title">
  <SectionContainer class="contact-section__inner">
    <div class="contact-copy reveal reveal-left">
      <p class="section-label">Contact and Wholesale</p>

      <h2 id="contact-title">Bring Ana’s Estate to Your Customers</h2>

      <div class="ornament" aria-hidden="true">◇</div>

      <p>
        Ana’s Estate is available for select restaurants, specialty grocers, farm markets and food
        retailers.
      </p>

      <p>
        For product questions, wholesale inquiries or retail partnerships, send us a message.
      </p>

      <div class="contact-details">
        <p>
          <strong>Email</strong>
          <br />
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>

        <p>
          <strong>Imported by</strong>
          <br />
          {SITE.importer}
          <br />
          {SITE.location}
        </p>
      </div>
    </div>

    <form class="contact-form reveal reveal-right" action={FORMSUBMIT_ACTION} method="POST">
      <input type="hidden" name="_subject" value="New Ana’s Estate website inquiry" />
      <input type="hidden" name="_captcha" value="false" />

      <label for="contact-name">Name</label>
      <input id="contact-name" type="text" name="name" autocomplete="name" required />

      <label for="contact-email">Email</label>
      <input id="contact-email" type="email" name="email" autocomplete="email" required />

      <label for="contact-subject">Subject</label>
      <input id="contact-subject" type="text" name="subject" />

      <label for="contact-message">Message</label>
      <textarea id="contact-message" name="message" rows="6" required></textarea>

      <button class="btn" type="submit">Send Message</button>
    </form>
  </SectionContainer>
</section>
