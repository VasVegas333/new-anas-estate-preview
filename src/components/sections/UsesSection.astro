---
import { Image } from 'astro:assets';
import { images } from '../../assets/images';

const uses = [
  { image: images.iconSalads, title: 'Salads' },
  { image: images.iconVegetables, title: 'Grilled Vegetables' },
  { image: images.iconSeafood, title: 'Seafood' },
  { image: images.iconBread, title: 'Bread Dipping' },
  { image: images.iconMeats, title: 'Meats' },
  { image: images.iconSoups, title: 'Soups' },
] as const;
---

<section class="uses-section" id="uses" aria-labelledby="uses-title">
  <div class="section-heading reveal">
    <p class="section-label">In the Kitchen</p>

    <p class="script">Perfect For</p>

    <div class="ornament" aria-hidden="true">◇</div>
  </div>

  <div class="uses-grid reveal-group">
    {
      uses.map((use) => (
        <article>
          <Image
            src={use.image}
            alt=""
            aria-hidden="true"
            loading="lazy"
            widths={[72, 144]}
            sizes="72px"
          />
          <h3>{use.title}</h3>
        </article>
      ))
    }
  </div>
</section>
